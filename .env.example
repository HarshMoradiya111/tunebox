# ===========================
# Spotify Clone — Environment
# ===========================

# --- Spotify API ---
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/auth/callback

# --- MongoDB ---
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/spotify-clone
# MongoDB Atlas (uncomment and use this instead for cloud)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spotify-clone?retryWrites=true&w=majority

# --- Backend Server ---
PORT=5000
NODE_ENV=development

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Cloudflare R2 (Phase 9 — leave blank for now) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- JWT Secret (for session management) ---
JWT_SECRET=your_jwt_secret_here
